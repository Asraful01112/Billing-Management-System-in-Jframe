    private void openStaffManagementDialog(String currentAdminUser) {
        DefaultListModel<String> userListModel = new DefaultListModel<>();
        for (Map.Entry<String, User> entry : LoginForm.userDatabase.entrySet()) {
            userListModel.addElement(entry.getKey() + " [" + entry.getValue().role + "]");
        }

        JList<String> userJList = new JList<>(userListModel);
        userJList.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        userJList.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);
        JScrollPane scrollPane = new JScrollPane(userJList);
        scrollPane.setPreferredSize(new Dimension(300, 180));

        Object[] dialogContent = {
            "Select User/Staff to Remove:",
            scrollPane
        };

        int option = JOptionPane.showOptionDialog(
                this,
                dialogContent,
                "Admin Staff Management Panel",
                JOptionPane.OK_CANCEL_OPTION,
                JOptionPane.PLAIN_MESSAGE,
                null,
                new String[]{"Remove Selected User", "Close"},
                "Remove Selected User"
        );

        if (option == JOptionPane.OK_OPTION) {
            String selectedValue = userJList.getSelectedValue();
            if (selectedValue == null) {
                JOptionPane.showMessageDialog(this, "Please select a user from the list to remove!", "Warning", JOptionPane.WARNING_MESSAGE);
                return;
            }

            String targetUser = selectedValue.split(" \\[")[0];

            if (targetUser.equals(currentAdminUser)) {
                JOptionPane.showMessageDialog(this, "You cannot remove your own active Admin account!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            }

            int confirm = JOptionPane.showConfirmDialog(
                    this, 
                    "Are you sure you want to remove user '" + targetUser + "'?", 
                    "Confirm User Removal", 
                    JOptionPane.YES_NO_OPTION, 
                    JOptionPane.WARNING_MESSAGE
            );

            if (confirm == JOptionPane.YES_OPTION) {
                LoginForm.userDatabase.remove(targetUser);
                JOptionPane.showMessageDialog(this, "User '" + targetUser + "' has been successfully removed!", "User Removed", JOptionPane.INFORMATION_MESSAGE);
            }
        }
    }

    private boolean verifyAdminPassword() {
        JPasswordField pf = new JPasswordField();
        int option = JOptionPane.showConfirmDialog(
                this, 
                new Object[]{"Enter Admin Password for Approval:", pf}, 
                "Admin Authorization Required", 
                JOptionPane.OK_CANCEL_OPTION, 
                JOptionPane.WARNING_MESSAGE
        );

        if (option == JOptionPane.OK_OPTION) {
            String enteredPassword = new String(pf.getPassword());
            User adminUser = LoginForm.userDatabase.get("Asraful");
            if (adminUser != null && adminUser.password.equals(enteredPassword)) {
                return true;
            } else {
                JOptionPane.showMessageDialog(this, "Incorrect Admin Password! Access Denied.", "Permission Denied", JOptionPane.ERROR_MESSAGE);
            }
        }
        return false;
    }

    private void deleteSelectedCartItem(int selectedRow) {
        String prodName = tableModel.getValueAt(selectedRow, 0).toString();
        int qty = Integer.parseInt(tableModel.getValueAt(selectedRow, 2).toString());
        double itemTotal = Double.parseDouble(tableModel.getValueAt(selectedRow, 3).toString());

        for (Product p : inventory) {
            if (p.name.equals(prodName)) {
                p.stock += qty;
                break;
            }
        }

        subTotal -= itemTotal;
        tableModel.removeRow(selectedRow);
        
        updateTotals();
        populateComboBox();
        JOptionPane.showMessageDialog(this, prodName + " removed from cart!", "Item Removed", JOptionPane.INFORMATION_MESSAGE);
    }

    private void populateComboBox() {
        cmbItems.removeAllItems();
        cmbItems.addItem("-- Select Item --");
        for (Product p : inventory) {
            if (p.stock > 0) {
                cmbItems.addItem(p.name + " (Stock: " + p.stock + ")");
            } else {
                cmbItems.addItem(p.name + " (OUT OF STOCK)");
            }
        }
    }

    private void openAdminInventoryManager() {
        String[] productNames = inventory.stream().map(p -> p.name).toArray(String[]::new);
        JComboBox<String> cmbSelectProduct = new JComboBox<>(productNames);
        JTextField txtEditPrice = new JTextField();
        JTextField txtEditStock = new JTextField();

        cmbSelectProduct.addActionListener(e -> {
            int idx = cmbSelectProduct.getSelectedIndex();
            if (idx >= 0) {
                txtEditPrice.setText(String.valueOf(inventory.get(idx).price));
                txtEditStock.setText(String.valueOf(inventory.get(idx).stock));
            }
        });
        if (productNames.length > 0) cmbSelectProduct.setSelectedIndex(0);

        Object[] message = {
            "Select Product to Edit:", cmbSelectProduct,
            "Edit Price ($):", txtEditPrice,
            "Edit Stock (Units):", txtEditStock
        };

        int option = JOptionPane.showConfirmDialog(this, message, "Admin Inventory Edit Panel", JOptionPane.OK_CANCEL_OPTION);
        if (option == JOptionPane.OK_OPTION) {
            try {
                int selectedIdx = cmbSelectProduct.getSelectedIndex();
                double newPrice = Double.parseDouble(txtEditPrice.getText().trim());
                int newStock = Integer.parseInt(txtEditStock.getText().trim());

                if (newPrice <= 0 || newStock < 0) {
                    JOptionPane.showMessageDialog(this, "Price/Stock must be valid non-negative values!", "Error", JOptionPane.ERROR_MESSAGE);
                    return;
                }

                Product prod = inventory.get(selectedIdx);
                prod.price = newPrice;
                prod.stock = newStock;

                populateComboBox();
                JOptionPane.showMessageDialog(this, "Product updated successfully!", "Admin Success", JOptionPane.INFORMATION_MESSAGE);

            } catch (NumberFormatException ex) {
                JOptionPane.showMessageDialog(this, "Invalid Price or Stock number entered!", "Error", JOptionPane.ERROR_MESSAGE);
            }
        }
    }

    private void addItemToCart() {
        try {
            int selectedIndex = cmbItems.getSelectedIndex();
            if (selectedIndex <= 0) {
                JOptionPane.showMessageDialog(this, "Please select an item from the list.", "Input Error", JOptionPane.ERROR_MESSAGE);
                return;
            }

            Product prod = inventory.get(selectedIndex - 1);

            if (prod.stock <= 0) {
                JOptionPane.showMessageDialog(this, "Sorry! This item is OUT OF STOCK.", "Stock Error", JOptionPane.ERROR_MESSAGE);
                return;
            }

            double price = prod.price;
            int qty = Integer.parseInt(txtQuantity.getText().trim());

            if (qty <= 0) {
                JOptionPane.showMessageDialog(this, "Quantity must be greater than zero.", "Input Error", JOptionPane.ERROR_MESSAGE);
                return;
            }

            if (qty > prod.stock) {
                JOptionPane.showMessageDialog(this, "Only " + prod.stock + " units available in stock!", "Stock Limit Error", JOptionPane.WARNING_MESSAGE);
                return;
            }

            double itemTotal = price * qty;

            tableModel.addRow(new Object[]{prod.name, String.format("%.2f", price), qty, String.format("%.2f", itemTotal)});

            prod.stock -= qty;

            subTotal += itemTotal;
            updateTotals();

            populateComboBox();
            txtPrice.setText("");
            txtQuantity.setText("");

        } catch (NumberFormatException ex) {
            JOptionPane.showMessageDialog(this, "Please enter a valid numeric value for Quantity.", "Input Error", JOptionPane.ERROR_MESSAGE);
        }
    }

    private void updateTotals() {
        double tax = subTotal * TAX_RATE;
        double discount = chkDiscount.isSelected() ? (subTotal * DISCOUNT_RATE) : 0.0;
        double grandTotal = (subTotal + tax) - discount;

        txtSubTotal.setText(String.format("%.2f", subTotal));
        txtTax.setText(String.format("%.2f", tax));
        txtTotal.setText(String.format("%.2f", grandTotal));
    }

    private void clearAll() {
        tableModel.setRowCount(0);
        subTotal = 0.0;
        chkDiscount.setSelected(false);
        txtComment.setText("");
        updateTotals();
        cmbItems.setSelectedIndex(0);
        txtPrice.setText("");
        txtQuantity.setText("");
    }
}
