    private void openRegistrationDialog() {
        if (userDatabase.size() >= 3) {
            JOptionPane.showMessageDialog(this, 
                "User limit reached! (Maximum 3 users: 1 Admin + 2 Staff allowed).\nRemove an existing user to add a new one.", 
                "Limit Reached", JOptionPane.WARNING_MESSAGE);
            return;
        }

        JTextField regUser = new JTextField();
        JPasswordField regPass = new JPasswordField();
        JComboBox<String> cmbRole = new JComboBox<>(new String[]{"STAFF", "ADMIN"});
        
        Object[] message = {
            "New Username:", regUser,
            "New Password:", regPass,
            "User Role:", cmbRole
        };

        int option = JOptionPane.showConfirmDialog(this, message, "Register New User", JOptionPane.OK_CANCEL_OPTION);
        if (option == JOptionPane.OK_OPTION) {
            String u = regUser.getText().trim();
            String p = new String(regPass.getPassword());
            String role = (String) cmbRole.getSelectedItem();

            if (u.isEmpty() || p.isEmpty()) {
                JOptionPane.showMessageDialog(this, "Fields cannot be empty!", "Error", JOptionPane.ERROR_MESSAGE);
                return;
            } 
            
            if (userDatabase.containsKey(u)) {
                JOptionPane.showMessageDialog(this, "Username already exists!", "Error", JOptionPane.WARNING_MESSAGE);
                return;
            }

            long adminCount = userDatabase.values().stream().filter(usr -> "ADMIN".equalsIgnoreCase(usr.role)).count();
            long staffCount = userDatabase.values().stream().filter(usr -> "STAFF".equalsIgnoreCase(usr.role)).count();

            if ("ADMIN".equalsIgnoreCase(role) && adminCount >= 1) {
                JOptionPane.showMessageDialog(this, "Admin limit reached! Only 1 Admin account is allowed.", "Role Limit", JOptionPane.WARNING_MESSAGE);
                return;
            }

            if ("STAFF".equalsIgnoreCase(role) && staffCount >= 2) {
                JOptionPane.showMessageDialog(this, "Staff limit reached! Only 2 Staff accounts are allowed.", "Role Limit", JOptionPane.WARNING_MESSAGE);
                return;
            }

            userDatabase.put(u, new User(p, role));
            JOptionPane.showMessageDialog(this, "User Registered Successfully as " + role + "!", "Success", JOptionPane.INFORMATION_MESSAGE);
        }
    }
}

