class BackgroundPanel extends JPanel {
    private BufferedImage backgroundImage;

    public BackgroundPanel(String imageUrl) {
        try {
            URL url = new URL(imageUrl);
            BufferedImage originalImage = ImageIO.read(url);
            if (originalImage != null) {
                this.backgroundImage = blurImage(originalImage);
            }
        } catch (IOException e) {
            System.out.println("Image loading failed: " + e.getMessage());
        }
    }

    private BufferedImage blurImage(BufferedImage img) {
        int radius = 11;
        int size = radius * 2 + 1;
        float[] matrix = new float[size * size];
        for (int i = 0; i < matrix.length; i++) {
            matrix[i] = 1.0f / (size * size);
        }
        Kernel kernel = new Kernel(size, size, matrix);
        ConvolveOp op = new ConvolveOp(kernel, ConvolveOp.EDGE_NO_OP, null);
        return op.filter(img, null);
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2d = (Graphics2D) g.create();
        
        if (backgroundImage != null) {
            g2d.drawImage(backgroundImage, 0, 0, getWidth(), getHeight(), this);
        } else {
            g2d.setColor(new Color(15, 23, 42));
            g2d.fillRect(0, 0, getWidth(), getHeight());
        }

        g2d.setColor(new Color(10, 15, 30, 160)); 
        g2d.fillRect(0, 0, getWidth(), getHeight());

        g2d.dispose();
    }
}

